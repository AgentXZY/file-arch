# ====================================================================
# 1. CMake & Local Machine Build Directories
# ====================================================================
# Excludes the entire auto-generated build directory and its internal artifacts
build/
.cmake/

# ====================================================================
# 2. Visual Studio & MSVC Compiler Noise
# ====================================================================
# Excludes individual Visual Studio project configurations generated by CMake
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.dir/
*.pdb
*.obj
*.exe
*.ilk

# ====================================================================
# 3. IDE & Editor Specific Settings
# ====================================================================
# Excludes VS Code and CLion workspace settings
.vscode/
.idea/